{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Hank",
    "scopeName": "source.hank",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#operators" },
        { "include": "#sigils" },
        { "include": "#function-calls" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [{
                "name": "comment.line.double-slash.hank",
                "match": "//.*$"
            }]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.hank",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [{ "name": "constant.character.escape.hank", "match": "\\\\." }]
                },
                {
                    "name": "string.quoted.single.hank",
                    "begin": "'",
                    "end": "'",
                    "patterns": [{ "name": "constant.character.escape.hank", "match": "\\\\." }]
                }
            ]
        },
        "numbers": {
            "patterns": [{
                "name": "constant.numeric.hank",
                "match": "\\b-?[0-9]+(\\.[0-9]+)?\\b"
            }]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flow.hank",
                    "match": "\\?"
                },
                {
                    "name": "keyword.operator.fallback.hank",
                    "match": ":"
                },
                {
                    "name": "keyword.control.rescue.hank",
                    "match": "~"
                },
                {
                    "name": "keyword.control.return.hank",
                    "match": "\\^"
                }
            ]
        },
        "sigils": {
            "patterns": [
                {
                    "name": "keyword.other.macro.hank",
                    "match": "@"
                },
                {
                    "name": "keyword.other.core-escape.hank",
                    "match": "#"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.hank",
                    "match": "!"
                },
                {
                    "name": "keyword.operator.assignment.hank",
                    "match": "="
                }
            ]
        },
        "function-calls": {
            "patterns": [
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.hank" }
                    }
                }
            ]
        },
        "punctuation": {
            "patterns": [
                { "name": "punctuation.definition.block.hank", "match": "[{}]" },
                { "name": "punctuation.definition.collection.hank", "match": "[\\[\\]]" },
                { "name": "punctuation.definition.parameters.hank", "match": "[()]" },
                { "name": "punctuation.separator.comma.hank", "match": "," }
            ]
        }
    }
}
