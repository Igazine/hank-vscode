{
    "name": "hank-vscode",
    "displayName": "Hank",
    "description": "VSCode support for the Hank symbolic orchestration language.",
    "version": "0.1.0",
    "publisher": "Igazine",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "hank",
                "aliases": [
                    "Hank",
                    "hank"
                ],
                "extensions": [
                    ".hank"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "hank",
                "scopeName": "source.hank",
                "path": "./syntaxes/hank.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "18.x",
        "typescript": "^5.1.3",
        "eslint": "^8.41.0",
        "@typescript-eslint/parser": "^5.59.8",
        "@typescript-eslint/eslint-plugin": "^5.59.8"
    }
}
