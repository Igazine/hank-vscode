{
    "name": "hank-vscode",
    "displayName": "Hank",
    "description": "VSCode support for the Hank symbolic orchestration language.",
    "version": "0.1.0",
    "publisher": "Igazine",
    "license": "MIT",
    "engines": {
        "vscode": "^1.80.0"
    },
    "activationEvents": [
        "onLanguage:hank"
    ],
    "main": "./client/out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "hank.runScript",
                "title": "Run Hank Script",
                "icon": "$(play)"
            }
        ],
        "menus": {
            "editor/title/run": [
                {
                    "command": "hank.runScript",
                    "when": "editorLangId == hank",
                    "group": "navigation"
                }
            ]
        },
        "languages": [
            {
                "id": "hank",
                "aliases": [
                    "Hank",
                    "hank"
                ],
                "extensions": [
                    ".hank"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "hank",
                "scopeName": "source.hank",
                "path": "./syntaxes/hank.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -b && npm run bundle",
        "bundle": "esbuild ./client/src/extension.ts --bundle --outfile=client/out/extension.js --external:vscode --format=cjs --platform=node --minify && esbuild ./server/src/server.ts --bundle --outfile=server/out/server.js --external:vscode --format=cjs --platform=node --minify",
        "watch": "tsc -b -w",
        "postinstall": "cd client && npm install && cd ../server && npm install",
        "test": "node ./client/out/test/runTest.js"
    },
    "devDependencies": {
        "esbuild": "^0.25.0",
        "typescript": "^5.1.3"
    }
}
